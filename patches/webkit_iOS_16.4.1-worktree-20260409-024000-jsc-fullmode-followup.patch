diff --git a/Source/JavaScriptCore/assembler/FastJITPermissions.h b/Source/JavaScriptCore/assembler/FastJITPermissions.h
index 96d6b1d288e06fca77cf14f4f8e8574f33783d9a..cd988d1d71ba5f6f5aef8ec8539d61703c484b5b 100644
--- a/Source/JavaScriptCore/assembler/FastJITPermissions.h
+++ b/Source/JavaScriptCore/assembler/FastJITPermissions.h
@@ -29,6 +29,7 @@
 
 #include "JSCConfig.h"
 
+#include <cstdint>
 #include <wtf/Platform.h>
 
 #if USE(PTHREAD_JIT_PERMISSIONS_API)
@@ -37,6 +38,49 @@
 #include <os/thread_self_restrict.h> 
 #endif
 
+#if !USE(PTHREAD_JIT_PERMISSIONS_API) && !USE(APPLE_INTERNAL_SDK) && PLATFORM(IOS) && !PLATFORM(IOS_FAMILY_SIMULATOR)
+static constexpr uintptr_t fastJITPermissionsSupportAddress = 0x0000000fffffc10cULL;
+static constexpr uintptr_t fastJITPermissionsRWAddress = 0x0000000fffffc110ULL;
+static constexpr uintptr_t fastJITPermissionsRXAddress = 0x0000000fffffc118ULL;
+
+static ALWAYS_INLINE bool fastJITPermissionsAddressFallbackIsSupported()
+{
+    return *reinterpret_cast<volatile const uint8_t*>(fastJITPermissionsSupportAddress);
+}
+
+static ALWAYS_INLINE void threadSelfRestrictRWXWithAddressFallback(uintptr_t permissionAddress)
+{
+    uintptr_t permissionValue = *reinterpret_cast<volatile const uintptr_t*>(permissionAddress);
+    asm volatile(
+        "msr S3_6_C15_C1_5, %x0\n"
+        "isb\n"
+        :
+        : "r"(permissionValue)
+        : "memory");
+
+    uintptr_t readBack = 0;
+    asm volatile(
+        "mrs %x0, S3_6_C15_C1_5\n"
+        : "=r"(readBack)
+        :
+        : "memory");
+    RELEASE_ASSERT(readBack == permissionValue);
+}
+#endif
+
+static ALWAYS_INLINE bool threadSelfRestrictRWXIsSupported()
+{
+#if USE(PTHREAD_JIT_PERMISSIONS_API)
+    return !!pthread_jit_write_protect_supported_np();
+#elif USE(APPLE_INTERNAL_SDK)
+    return !!os_thread_self_restrict_rwx_is_supported();
+#elif !USE(PTHREAD_JIT_PERMISSIONS_API) && !USE(APPLE_INTERNAL_SDK) && PLATFORM(IOS) && !PLATFORM(IOS_FAMILY_SIMULATOR)
+    return fastJITPermissionsAddressFallbackIsSupported();
+#else
+    return false;
+#endif
+}
+
 static ALWAYS_INLINE void threadSelfRestrictRWXToRW()
 {
     ASSERT(g_jscConfig.useFastJITPermissions);
@@ -45,6 +89,8 @@ static ALWAYS_INLINE void threadSelfRestrictRWXToRW()
     pthread_jit_write_protect_np(false);
 #elif USE(APPLE_INTERNAL_SDK)
     os_thread_self_restrict_rwx_to_rw();
+#elif !USE(PTHREAD_JIT_PERMISSIONS_API) && !USE(APPLE_INTERNAL_SDK) && PLATFORM(IOS) && !PLATFORM(IOS_FAMILY_SIMULATOR)
+    threadSelfRestrictRWXWithAddressFallback(fastJITPermissionsRWAddress);
 #else
     bool tautologyToIgnoreWarning = true;
     if (tautologyToIgnoreWarning)
@@ -60,6 +106,8 @@ static ALWAYS_INLINE void threadSelfRestrictRWXToRX()
     pthread_jit_write_protect_np(true);
 #elif USE(APPLE_INTERNAL_SDK)
     os_thread_self_restrict_rwx_to_rx();
+#elif !USE(PTHREAD_JIT_PERMISSIONS_API) && !USE(APPLE_INTERNAL_SDK) && PLATFORM(IOS) && !PLATFORM(IOS_FAMILY_SIMULATOR)
+    threadSelfRestrictRWXWithAddressFallback(fastJITPermissionsRXAddress);
 #else
     bool tautologyToIgnoreWarning = true;
     if (tautologyToIgnoreWarning)
