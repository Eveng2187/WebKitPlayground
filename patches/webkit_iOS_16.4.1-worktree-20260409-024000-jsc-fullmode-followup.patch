+
+static ALWAYS_INLINE void threadSelfRestrictRWXWithAddressFallback(uintptr_t permissionAddress)
+{
+    uintptr_t permissionValue = *reinterpret_cast<volatile const uintptr_t*>(permissionAddress);
+    asm volatile(
+        "msr S3_6_C15_C1_5, %x0\n"
+        "isb\n"
+        :
+        : "r"(permissionValue)
+        : "memory");
+
+    uintptr_t readBack = 0;
+    asm volatile(
+        "mrs %x0, S3_6_C15_C1_5\n"
+        : "=r"(readBack)
+        :
+        : "memory");
+    RELEASE_ASSERT(readBack == permissionValue);
+}
+#endif
+
+static ALWAYS_INLINE bool threadSelfRestrictRWXIsSupported()
+{
+#if USE(PTHREAD_JIT_PERMISSIONS_API)
+    return !!pthread_jit_write_protect_supported_np();
+#elif USE(APPLE_INTERNAL_SDK)
+    return !!os_thread_self_restrict_rwx_is_supported();
+#elif !USE(PTHREAD_JIT_PERMISSIONS_API) && !USE(APPLE_INTERNAL_SDK) && PLATFORM(IOS) && !PLATFORM(IOS_FAMILY_SIMULATOR)
+    return fastJITPermissionsAddressFallbackIsSupported();
+#else
+    return false;
+#endif
+}
